func main() {
    print("=== Statistics Module ===");
    let data = [10, 20, 30, 40, 50];
    print("data:", data);
    print("sum:", stats.sum(data));
    print("mean:", stats.mean(data));
    print("median:", stats.median(data));
    print("min:", stats.min(data));
    print("max:", stats.max(data));
    print("variance:", stats.variance(data));
    print("std:", stats.std(data));

    print("");
    print("=== Quantiles ===");
    print("q0.25:", stats.quantile(data, 0.25));
    print("q0.5:", stats.quantile(data, 0.5));
    print("q0.75:", stats.quantile(data, 0.75));

    print("");
    print("=== Correlation ===");
    let x = [1, 2, 3, 4, 5];
    let y = [2, 4, 6, 8, 10];
    print("covariance:", stats.covariance(x, y));
    print("correlation:", stats.correlation(x, y));

    print("");
    print("=== Data Preprocessing ===");
    let raw = [100, 200, 300, 400, 500];
    print("normalized:", stats.normalize(raw));
    print("standardized:", stats.standardize(raw));

    print("");
    print("=== ALL ML TESTS PASSED ===");
}
