func main() {
    let win = graphics.init("Test", 320, 240);
    win.draw_text(10, 100, "Press ESC to quit", (255, 255, 255));
    win.present();

    let running = true;
    while running {
        let events = win.poll_events();
        for ev in events {
            if ev == "quit" {
                running = false;
            }
        }
    }
    print("exited");
    win.close();
}
