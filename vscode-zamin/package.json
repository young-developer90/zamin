{
  "name": "zamin-lang",
  "displayName": "Zamin Language",
  "description": "Zamin scripting language — syntax highlighting, snippets, and LSP support",
  "version": "0.2.0",
  "publisher": "zamin-lang",
  "icon": "icon.ico",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages", "Language Servers"],
  "activationEvents": ["onLanguage:zamin"],
  "main": "./src/extension.js",
  "contributes": {
    "languages": [{
      "id": "zamin",
      "aliases": ["Zamin", "zamin"],
      "extensions": [".zamin"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "zamin",
      "scopeName": "source.zamin",
      "path": "./syntaxes/zamin.tmLanguage.json"
    }],
    "snippets": [{
      "language": "zamin",
      "path": "./snippets/zamin.json"
    }]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
