// Sol GUI demo
// Run with: zamin run examples/sol_demo.lion

let root = sol.Leo("Sol Demo", 400, 300);

let label = sol.Label(root, "Hello from Sol!");
sol.pack(label, "top", 0, 10);

let entry = sol.Entry(root);
sol.pack(entry, "top", 0, 10);
sol.insert(entry, 0, "Type something");

sol.title(root, "Sol Demo");
sol.geometry(root, 400, 300);

sol.messagebox("Ready!", "Sol");
print("Starting mainloop...");

sol.mainloop(root);
print("Done!");
