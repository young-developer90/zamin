// Luna GUI test
let root = luna.Leo("Luna Test", 400, 300);
let label = luna.Label(root, "Hello from Luna!");
luna.pack(label);
let btn = luna.Button(root, "Click me", func() {
    luna.config(label, "text", "Clicked!");
});
luna.pack(btn);
let entry = luna.Entry(root);
luna.pack(entry);
let get_btn = luna.Button(root, "Get text", func() {
    let val = luna.get(entry);
    luna.config(label, "text", val);
});
luna.pack(get_btn);
print("Luna GUI loaded, starting mainloop...");
luna.mainloop(root);
